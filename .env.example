# Docker Compose defaults (safe to use for local development)
POSTGRES_USER=lnu
POSTGRES_PASSWORD=lnu123
POSTGRES_DB=lnu_assets
POSTGRES_PORT=5432

# Published ports on host machine
API_PORT=3000
WEB_PORT=3001

# Frontend runtime/build API endpoints
# Browser-to-API URL (same-origin proxy through Next.js)
NEXT_PUBLIC_API_URL=/api
# Server-side URL used by Next.js rewrite inside the web container
INTERNAL_API_URL=http://lnu_api:3000

# Session timeout in milliseconds (default: 30 minutes)
NEXT_PUBLIC_SESSION_TIMEOUT_MS=1800000

# JWT signing secret used by the API
JWT_SECRET=replace_with_long_random_secret

# Optional local (non-Docker) API database URL example:
# DATABASE_URL=postgresql://lnu:lnu123@localhost:5432/lnu_assets?schema=public
